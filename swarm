#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAIN_BRANCH="${SWARMFORGE_SCRIPTS_BRANCH:-main}"
ARCHIVE_URL="${SWARMFORGE_SCRIPTS_URL:-https://github.com/unclebob/swarm-forge/archive/refs/heads/${MAIN_BRANCH}.tar.gz}"
TMP_DIR=""

cleanup() {
  if [[ -n "$TMP_DIR" ]]; then
    rm -rf "$TMP_DIR"
  fi
}
trap cleanup EXIT

if [[ ! -d "$SCRIPT_DIR/swarmforge/scripts" || ! -d "$SCRIPT_DIR/swarmforge/scripts/shared-articles" ]]; then
  TMP_DIR="$(mktemp -d)"
  mkdir -p "$SCRIPT_DIR/swarmforge"
  curl -L "$ARCHIVE_URL" | tar -xz --strip-components=1 -C "$TMP_DIR"
  if [[ ! -d "$SCRIPT_DIR/swarmforge/scripts" ]]; then
    cp -R "$TMP_DIR/swarmforge/scripts" "$SCRIPT_DIR/swarmforge/scripts"
  fi
  if [[ -d "$TMP_DIR/swarmforge/constitution/articles" ]]; then
    mkdir -p "$SCRIPT_DIR/swarmforge/scripts/shared-articles"
    cp -R "$TMP_DIR/swarmforge/constitution/articles/." "$SCRIPT_DIR/swarmforge/scripts/shared-articles/"
  fi
fi

# Estimate mutation_cost for paused backlog items if not set
if [[ -d "$SCRIPT_DIR/backlog/paused" ]]; then
  # BL-224: with nullglob off (bash's default), a non-matching glob leaves the
  # literal pattern string as the loop variable instead of the loop running
  # zero times - grep then fails on that nonexistent path ("No such file or
  # directory" noise) and the else branch appends to it, CREATING a real file
  # literally named "*.yaml" in backlog/paused/. Scoping nullglob around just
  # this loop makes an empty paused/ iterate zero times, as intended.
  shopt -s nullglob
  for item in "$SCRIPT_DIR/backlog/paused"/*.yaml; do
    if ! grep -q "mutation_cost:" "$item"; then
      if grep -qiE "auth|login|payment|migration|refactor|large|complex" "$item"; then
        echo "mutation_cost: high" >> "$item"
      elif grep -qiE "fix|typo|docs|config|small" "$item"; then
        echo "mutation_cost: low" >> "$item"
      else
        echo "mutation_cost: medium" >> "$item"
      fi
    fi
  done
  shopt -u nullglob
fi

exec "$SCRIPT_DIR/swarmforge/scripts/swarmforge.sh" "$@"
