{
  "$schema": "./node_modules/@stryker-mutator/core/schema/stryker-schema.json",
  "testRunner": "vitest",
  "vitest": {
    "configFile": "vitest.config.mjs",
    "related": false
  },
  "mutate": [
    "out/**/*.js"
  ],
  "incremental": true,
  "incrementalFile": "stryker-incremental.json",
  "concurrency": 4,
  "timeoutMS": 60000,
  "timeoutFactor": 3,
  "coverageAnalysis": "perTest",
  "appendPlugins": ["./out/mutation/stryker-plugin.js"],
  "reporters": ["clear-text", "progress", "mutation-progress"],
  "tempDirName": ".stryker-tmp",
  "cleanTempDir": true
}
