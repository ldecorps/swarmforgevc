{
  "name": "swarmforge-vc",
  "displayName": "SwarmForge VC",
  "description": "Visual front-end for SwarmForge multi-agent orchestration",
  "version": "0.1.0",
  "publisher": "swarmforge",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:swarmforge.testTmux",
    "onCommand:swarmforge.setTarget",
    "onCommand:swarmforge.initializeTarget",
    "onCommand:swarmforge.launchSwarm",
    "onCommand:swarmforge.stopSwarm",
    "onCommand:swarmforge.openPanel",
    "onCommand:swarmforge.openPR",
    "onCommand:swarmforge.showRuns"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "swarmforge.testTmux",
        "title": "SwarmForge: Test Tmux Connection"
      },
      {
        "command": "swarmforge.setTarget",
        "title": "SwarmForge: Set Target Project"
      },
      {
        "command": "swarmforge.initializeTarget",
        "title": "SwarmForge: Initialize Target"
      },
      {
        "command": "swarmforge.launchSwarm",
        "title": "SwarmForge: Launch Swarm"
      },
      {
        "command": "swarmforge.stopSwarm",
        "title": "SwarmForge: Stop Swarm"
      },
      {
        "command": "swarmforge.openPanel",
        "title": "SwarmForge: Open Panel"
      },
      {
        "command": "swarmforge.openPR",
        "title": "SwarmForge: Open Pull Request"
      },
      {
        "command": "swarmforge.showRuns",
        "title": "SwarmForge: Show Run History"
      },
      {
        "command": "swarmforge.showWorkTree",
        "title": "SwarmForge: Show Work Tree"
      },
      {
        "command": "swarmforge.setRunMode",
        "title": "SwarmForge: Set Run Mode"
      },
      {
        "command": "swarmforge.drainCheck",
        "title": "SwarmForge: Check Drain Mode (Next Item)"
      }
    ],
    "configuration": {
      "title": "SwarmForge",
      "properties": {
        "swarmforge.targetPath": {
          "type": "string",
          "default": "",
          "description": "Path to the target project for SwarmForge runs."
        },
        "swarmforge.agentCommand": {
          "type": "string",
          "default": "claude",
          "description": "Reserved for future standalone orchestrator mode. Launch Swarm uses ./swarm and swarmforge/swarmforge.conf."
        },
        "swarmforge.agentArgs": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "--dangerously-skip-permissions"
          ],
          "description": "Reserved for future standalone orchestrator mode. Agent CLI flags belong in swarmforge/swarmforge.conf."
        },
        "swarmforge.roles": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "coder",
            "cleaner"
          ],
          "description": "Reserved for future standalone orchestrator mode. Active roles come from swarmforge/swarmforge.conf via ./swarm."
        },
        "swarmforge.comms.chaseIntervalSeconds": {
          "type": "number",
          "default": 30,
          "description": "How often (seconds) the InboxChaser sweeps each role's inbox/new/ for stale handoffs."
        },
        "swarmforge.comms.chaseTimeoutSeconds": {
          "type": "number",
          "default": 90,
          "description": "How old (seconds) a handoff must be before the chaser re-notifies the recipient."
        },
        "swarmforge.comms.maxChases": {
          "type": "number",
          "default": 3,
          "description": "Maximum number of chase wake-ups before a handoff is dead-lettered."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test": "npm run compile && node --test test/*.test.js",
    "tracer-bullet": "npm run compile && node out/tools/tracer-bullet-launcher.js"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "c8": "^11.0.0",
    "typescript": "^5.3.3"
  }
}
